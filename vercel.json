{
  "regions": ["sin1"],
  "rewrites": [
    {
      "source": "/api/images/:path*",
      "destination": "https://r2-worker.nrvsrpl.workers.dev/api/images/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}